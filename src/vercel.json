{
    "version": 2,
    "builds": [
      {
        "src": "src/main.tsx",
        "use": "@vercel/static-build",
        "config": {
          "distDir": "dist"
        }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/"
      }
    ],
    "env": {
      "REACT_APP_BACKEND_URL": "https://your-backend.vercel.app"
    }
  }